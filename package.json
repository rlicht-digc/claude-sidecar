{
  "name": "claude-sidecar",
  "version": "0.1.0",
  "description": "Real-time visual companion for Claude Code terminal sessions",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "setup-hooks": "bash scripts/setup-hooks.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "sidecar",
    "developer-tools",
    "visualization",
    "real-time",
    "websocket",
    "hooks"
  ],
  "author": "Russell Licht",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rlicht-digc/claude-sidecar.git"
  }
}
